    "@storybook/react-webpack5": "^8.4.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "^8.4.7",
